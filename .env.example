# ============================================================================
# OpenBudget Backend - Environment Variables
# Copy this file to .env and update with your production values
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_USER=openbudget
POSTGRES_PASSWORD=change_this_secure_password_123
POSTGRES_DB=openbudget
DATABASE_URL=postgresql://openbudget:change_this_secure_password_123@db:5432/openbudget
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
APP_NAME=OpenBudget API
APP_VERSION=1.0.0
DEBUG=False
API_V1_PREFIX=/api/v1

# ============================================================================
# SECURITY CONFIGURATION (CRITICAL - MUST CHANGE IN PRODUCTION)
# ============================================================================
# Generate a secure random key with: openssl rand -hex 32
SECRET_KEY=change_this_to_a_very_secure_random_key_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Update with your frontend URLs (JSON array format)
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ============================================================================
# COOKIE CONFIGURATION
# ============================================================================
COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
COOKIE_DOMAIN=yourdomain.com
COOKIE_SECURE=true
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ============================================================================
# SEED CONFIGURATION
# ============================================================================
# Set to "true" on FIRST deployment only to populate initial data
# Set to "false" after first run
RUN_SEED=true
