# Production Environment Variables
# Copy this file to .env.prod and fill in your production values

# Database
POSTGRES_USER=openbudget
POSTGRES_PASSWORD=your-strong-production-password-here
POSTGRES_DB=openbudget
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Application
APP_NAME=OpenBudget API
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1

# Security - IMPORTANT: Generate a strong secret key
SECRET_KEY=your-very-strong-secret-key-here-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - Update with your production domain
ALLOWED_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
